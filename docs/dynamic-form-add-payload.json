  "linkageRules": [
    {
      "name": "未成年隐藏手机号",
      "targetFieldId": "phone",
      "actionType": "HIDE",
      "enable": true,
      "sortOrder": 0,
      "conditionTree": [
        {
          "nodeType": "AND",
          "children": [
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "age",
              "triggerCondition": "LT",
              "triggerValue": "18"
            }
          ]
        }
      ]
    },
    {
      "name": "女性专属爱好选项",
      "targetFieldId": "hobbies",
      "actionType": "OPTION",
      "actionValue": [
        "makeup",
        "shopping",
        "yoga"
      ],
      "enable": true,
      "sortOrder": 1,
      "conditionTree": [
        {
          "nodeType": "AND",
          "children": [
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "gender",
              "triggerCondition": "EQ",
              "triggerValue": "female"
            }
          ]
        }
      ]
    },
    {
      "name": "激活时简介必填",
      "targetFieldId": "bio",
      "actionType": "REQUIRED",
      "actionValue": true,
      "enable": true,
      "sortOrder": 2,
      "conditionTree": [
        {
          "nodeType": "AND",
          "children": [
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "isActive",
              "triggerCondition": "EQ",
              "triggerValue": "true"
            }
          ]
        }
      ]
    },
    {
      "name": "北京用户红色主题",
      "targetFieldId": "themeColor",
      "actionType": "VALUE",
      "actionValue": "#FF0000",
      "enable": true,
      "sortOrder": 3,
      "conditionTree": [
        {
          "nodeType": "AND",
          "children": [
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "city",
              "triggerCondition": "EQ",
              "triggerValue": "beijing"
            }
          ]
        }
      ]
    },
    {
      "name": "成年男性禁用邮箱",
      "targetFieldId": "email",
      "actionType": "DISABLED",
      "actionValue": true,
      "enable": true,
      "sortOrder": 4,
      "conditionTree": [
        {
          "nodeType": "AND",
          "children": [
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "age",
              "triggerCondition": "GE",
              "triggerValue": "18"
            },
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "gender",
              "triggerCondition": "EQ",
              "triggerValue": "male"
            }
          ]
        }
      ]
    },
    {
      "name": "特定城市简介字数限制",
      "targetFieldId": "bio",
      "actionType": "SET_PATTERN",
      "actionValue": {
        "pattern": "^[\\s\\S]{10,200}$",
        "patternTips": "简介需要10-200字"
      },
      "enable": true,
      "sortOrder": 5,
      "conditionTree": [
        {
          "nodeType": "OR",
          "children": [
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "city",
              "triggerCondition": "EQ",
              "triggerValue": "shanghai"
            },
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "city",
              "triggerCondition": "EQ",
              "triggerValue": "guangzhou"
            }
          ]
        }
      ]
    },
    {
      "name": "填写日期后调整注册时间宽度",
      "targetFieldId": "registerTime",
      "actionType": "SET_SPAN",
      "actionValue": {
        "span": 12
      },
      "enable": true,
      "sortOrder": 6,
      "conditionTree": [
        {
          "nodeType": "AND",
          "children": [
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "birthDate",
              "triggerCondition": "NOT_EMPTY",
              "triggerValue": ""
            }
          ]
        }
      ]
    },
    {
      "name": "技术部启用进度条",
      "targetFieldId": "progress",
      "actionType": "ENABLED",
      "actionValue": true,
      "enable": true,
      "sortOrder": 7,
      "conditionTree": [
        {
          "nodeType": "AND",
          "children": [
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "department",
              "triggerCondition": "IN",
              "triggerValue": "tech"
            }
          ]
        }
      ]
    }
