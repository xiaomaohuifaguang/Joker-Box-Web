{
  "formFields": [
    {
      "fieldId": "expenseItems",
      "title": "费用明细",
      "type": "TABLE",
      "required": "1",
      "span": 24,
      "min": 1,
      "max": 5,
      "columns": [
        {
          "key": "itemName",
          "title": "费用名称"
        },
        {
          "key": "amount",
          "title": "金额"
        },
        {
          "key": "remark",
          "title": "备注"
        }
      ],
      "defaultValue": [
        {
          "itemName": "交通费",
          "amount": "100",
          "remark": "市内交通"
        }
      ]
    },
    {
      "fieldId": "needInvoice",
      "title": "是否需要发票",
      "type": "SWITCH",
      "required": "0",
      "span": 12,
      "defaultValue": false
    },
    {
      "fieldId": "invoiceTitle",
      "title": "发票抬头",
      "type": "INPUT",
      "required": "0",
      "span": 12
    }
  ],
  "linkageRules": [
    {
      "name": "有费用明细时要求填写发票抬头",
      "targetFieldId": "invoiceTitle",
      "actionType": "REQUIRED",
      "actionValue": true,
      "enable": true,
      "sortOrder": 1,
      "conditionTree": [
        {
          "nodeType": "AND",
          "children": [
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "expenseItems",
              "triggerCondition": "NOT_EMPTY"
            },
            {
              "nodeType": "CONDITION",
              "triggerFieldId": "needInvoice",
              "triggerCondition": "EQ",
              "triggerValue": "true"
            }
          ]
        }
      ]
    }
  ],
  "submitData": {
    "expenseItems": [
      {
        "itemName": "交通费",
        "amount": "100",
        "remark": "市内交通"
      },
      {
        "itemName": "住宿费",
        "amount": "300",
        "remark": "一晚"
      }
    ],
    "needInvoice": "true",
    "invoiceTitle": "北京某某科技有限公司"
  }
}
